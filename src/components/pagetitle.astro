---
const { align = "center" } = Astro.props;
---

<div class:list={[
  "py-12 md:py-20 mb-10 md:mb-16 rounded-3xl bg-gradient-to-b from-gray-50 to-white dark:from-gray-900/50 dark:to-black border border-gray-100 dark:border-gray-800/50 shadow-sm",
  align === "center" ? "text-center flex flex-col items-center" : "text-left flex flex-col items-start"
]}>
  <h1
    class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-primary-500 to-purple-500 mb-4 px-4 pb-2">
    <slot name="title">Title</slot>
  </h1>
  <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-2xl leading-relaxed px-4">
    <slot name="desc">Some description goes here</slot>
  </p>
</div>
