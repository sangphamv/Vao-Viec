---
interface Props {
  title: string;
  description?: string;
  fileSize: string;
  fileType: string;
  url: string;
  waitTime?: number;
}

const { title, description, fileSize, fileType, url, waitTime = 5 } = Astro.props;
const fileExt = fileType.toLowerCase();
const isZip = fileExt === 'zip';
const isPdf = fileExt === 'pdf';
const isPsd = fileExt === 'psd';
---

<div class="not-prose my-8 p-5 bg-light-card dark:bg-dark-card border border-light-surface/50 dark:border-dark-surface rounded-xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5 shadow-lg hover:shadow-xl transition-shadow">
  
  <div class="flex items-center gap-4 w-full">
    <!-- Icon Placeholder theo định dạng file -->
    <div class={`flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-white font-bold text-sm shadow-inner ${isZip ? 'bg-amber-600' : isPdf ? 'bg-red-600' : isPsd ? 'bg-blue-600' : 'bg-slate-600'}`}>
      {fileType.toUpperCase()}
    </div>
    
    <div class="flex-grow">
      <h4 class="text-base font-semibold text-light-foreground dark:text-dark-foreground m-0">{title}</h4>
      {description && <p class="text-sm text-light-muted dark:text-dark-muted mt-1 mb-0 line-clamp-1">{description}</p>}
      <div class="flex items-center gap-3 mt-1.5 text-xs text-light-muted dark:text-dark-muted font-medium">
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4 text-light-muted dark:text-dark-muted" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
          </svg>
          {fileSize}
        </span>
      </div>
    </div>
  </div>

  <button
    class="dl-btn group relative flex-shrink-0 w-full sm:w-44 h-11 bg-light-accent dark:bg-dark-accent text-white hover:opacity-90 rounded-lg text-sm font-semibold transition-colors duration-200 flex items-center justify-center disabled:opacity-80"
    data-url={url}
    data-wait={waitTime}
  >
    <span class="dl-text flex items-center gap-2">
      <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
      </svg>
      Tải xuống
    </span>
  </button>
</div>

<script>
  function initDownloadButtons() {
    const buttons = document.querySelectorAll('.dl-btn');
    
    buttons.forEach((btn) => {
      if (btn.hasAttribute('data-init')) return;
      btn.setAttribute('data-init', 'true');
      
      let timerId: ReturnType<typeof setInterval>;
      
      btn.addEventListener('click', (e) => {
        const button = e.currentTarget as HTMLButtonElement;
        const textSpan = button.querySelector('.dl-text');
        if (!textSpan) return;
        
        // Ngăn click đúp khi đang chờ
        if (button.hasAttribute('disabled')) return;
        
        const url = button.dataset.url;
        let waitTime = parseInt(button.dataset.wait || '5');
        
        // Khóa nút và đổi giao diện sang trạng thái chờ
        button.setAttribute('disabled', 'true');
        button.classList.add('!bg-slate-400', 'dark:!bg-slate-700');
        
        const updateText = () => {
          textSpan.innerHTML = `Vui lòng chờ... ${waitTime}s`;
        };
        updateText();
        
        // Bắt đầu đếm ngược
        timerId = setInterval(() => {
          waitTime--;
          updateText();
          
          if (waitTime <= 0) {
            clearInterval(timerId);
            
            // Xử lý khi đếm xong
            textSpan.innerHTML = `
              <svg class="w-4 h-4 text-emerald-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg> 
              Đang tải file!
            `;
            button.classList.remove('!bg-slate-400', 'dark:!bg-slate-700');
            button.classList.add('!bg-emerald-900/50', '!border', '!border-emerald-500');
            
            // Tự động kích hoạt tải file bằng thẻ <a> ẩn
            if (url) {
              const a = document.createElement('a');
              a.href = url;
              a.download = '';
              document.body.appendChild(a);
              a.click();
              document.body.removeChild(a);
            }
            
            // Reset nút bấm sau 3 giây để họ có thể tải lại nếu cần
            setTimeout(() => {
              button.removeAttribute('disabled');
              button.classList.remove('!bg-emerald-900/50', '!border', '!border-emerald-500');
              textSpan.innerHTML = `
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
                Tải xuống
              `;
            }, 3000);
          }
        }, 1000);
      });
    });
  }

  // Khởi tạo chạy trên MPA bình thường
  initDownloadButtons();
  // Lắng nghe sự kiện cho View Transitions
  document.addEventListener('astro:page-load', initDownloadButtons);
</script>
