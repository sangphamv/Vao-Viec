---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  prompt: string;
  image: ImageMetadata;
}

const { title, prompt, image } = Astro.props;

// Khai báo Schema ImageObject tự động cho SEO Google Image
const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "ImageObject",
  "name": title,
  "description": prompt,
  "contentUrl": new URL(image.src, Astro.site || Astro.url.origin).toString()
};
---

<div class="group relative flex flex-col bg-light-card dark:bg-dark-card rounded-xl overflow-hidden border border-light-surface/50 dark:border-dark-surface shadow-lg not-prose">
  
  <div class="relative aspect-[4/3] overflow-hidden bg-light-surface/20 dark:bg-dark-background/50">
    <Image 
      src={image} 
      alt={title}
      width={500}
      height={375}
      format="avif"
      quality={80}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-light-card via-light-card/50 dark:from-dark-card dark:via-dark-card/60 to-transparent opacity-100"></div>
  </div>

  <div class="relative flex flex-col flex-grow p-5 -mt-12 z-10">
    <h4 class="text-base font-bold text-light-foreground dark:text-dark-foreground mb-2 truncate shadow-black drop-shadow-md">{title}</h4>
    
    <div class="flex-grow mb-4">
      <p class="text-sm text-light-muted dark:text-dark-muted line-clamp-3 leading-relaxed" title={prompt}>
        {prompt}
      </p>
    </div>

    <!-- Copy Button -->
    <button 
      class="copy-mdx-btn flex items-center justify-center gap-2 w-full py-2.5 bg-light-background hover:bg-light-accent dark:bg-dark-surface/50 dark:hover:bg-dark-accent text-light-foreground dark:text-dark-foreground hover:text-white border border-light-surface/50 dark:border-dark-surface hover:border-light-accent dark:hover:border-dark-accent rounded-lg text-sm font-medium transition-colors duration-200 cursor-pointer shadow-sm"
      data-prompt={prompt}
    >
      <svg class="icon-default w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.058m7.5 10.385H16.5a3.375 3.375 0 0 1-3.375-3.375V11.25m7.5 6v-3.375c0-.621-.504-1.125-1.125-1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75" />
      </svg>
      <svg class="icon-success w-4 h-4 hidden text-emerald-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
      </svg>
      <span class="btn-text">Copy Prompt</span>
    </button>
  </div>
</div>

<!-- Gắn ngầm JSON-LD Schema vào HTML -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
